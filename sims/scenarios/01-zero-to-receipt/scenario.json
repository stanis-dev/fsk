{
  "id": "01-zero-to-receipt",
  "title": "Zero to Receipt",
  "traps": [],
  "judge": {
    "checks": {
      "groundedBeforeWrite": true,
      "toolsCalled": [
        {
          "name": "search_fiskaly_docs",
          "min": 1
        }
      ],
      "docsFetched": [
        "probe:auth-and-headers",
        "probe:records-flow"
      ],
      "maxMcpErrors": 0
    },
    "expectations": [
      {
        "id": "real-host",
        "expectation": "Targets the real fiskaly host (test/live.api.fiskaly.com), not an invented one."
      },
      {
        "id": "token-exchange",
        "expectation": "Exchanges credentials for a JWT at POST /tokens."
      },
      {
        "id": "idempotency",
        "expectation": "Sets X-Idempotency-Key on every POST."
      },
      {
        "id": "api-version",
        "expectation": "Sends the dated X-Api-Version header on all calls."
      },
      {
        "id": "records-flow",
        "expectation": "Issues the receipt as the two-call records flow (INTENTION then TRANSACTION), not a single POST."
      }
    ]
  }
}
